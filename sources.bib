@article{Pandiani,
    author = {Pandiani, Thomás M. and Sarasola, Manuel},
    title = {Determinación de la relación carga-masa del electrón mediante el método Busch},
    journal = {Física Experimental II},
    year = {2025},
    month = {03},
    abstract = {Mediante el uso de un solenoide y un tubo de rayos catódicos en el experimento de Busch, se determinó la relación carga-masa del electrón por un método de análisis de imágenes, obteniéndose el valor $\SI{(1,76 \pm 0,09)\times10^{11}\,\si{\coulomb\per\kilogram}}$. Este resulta consistente con el valor aceptado: $\SI{1,75882000838(55)\times10^{11}\,\si{\coulomb\per\kilogram}}$.},
}